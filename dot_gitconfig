[user]
	name = Alexey Troshin
	email = alexey.troshin.dev@gmail.com
[filter "lfs"]
	required = true
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
[core]
	autocrlf = input
	editor = nvim
[alias]
	rst = commit --amend --no-edit --reset-author
[merge]
	tool = nvimdiff
[mergetool "nvimdiff"]
	cmd = nvim -d \"$LOCAL\" \"$MERGED\" \"$REMOTE\"
[mergetool]
	keepBackup = false
